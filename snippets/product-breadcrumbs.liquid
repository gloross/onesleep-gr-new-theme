{%- if collection.url -%}
  {% assign url = collection.url %}
  {% assign text = collection.title %}
{%- else -%}
  {% assign url = routes.all_products_collection_url %}
  {% assign text = collections.all.title %}
{%- endif -%}

<a href="{{ url }}" class="product-breadcrumbs {{ class }}">
  {% render 'icon-arrow-long-left' %}
  {{ text }}
</a>
