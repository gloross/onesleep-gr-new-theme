{%- liquid
  assign _section = section.settings
  assign use_timer = _section.use_timer | default: false
  assign is_visible = false
  assign start_time_hour = _section.start_time | split: ':' | first | times: 1
  assign start_time_minute = _section.start_time | split: ':' | last
  assign end_time_hour = _section.end_time | split: ':' | first | times: 1
  assign end_time_minute = _section.end_time | split: ':' | last

  capture starting_date
    echo _section.start_date
    echo ' '
    case _section.start_period
      when 'am'
        case start_time_hour
          when 0, 12
            echo '00' | append: ':' | append: start_time_minute
          else
            echo _section.start_time
        endcase

      when 'pm'
        capture hour
          case start_time_hour
            when 0, 12
              echo '12'
            else
              if start_time_hour < 12
                echo start_time_hour | plus: 12
              else
                echo start_time_hour
              endif
          endcase
        endcapture

        echo hour | append: ':' | append: start_time_minute
    endcase
  endcapture

  capture expiration_date
    echo _section.end_date
    echo ' '
    case _section.end_period
      when 'am'
        case end_time_hour
          when 0, 12
            echo '00' | append: ':' | append: end_time_minute
          else
            echo _section.end_time
        endcase

      when 'pm'
        capture hour
          case end_time_hour
            when 0, 12
              echo '12'
            else
              if end_time_hour < 12
                echo end_time_hour | plus: 12
              else
                echo end_time_hour
              endif
          endcase
        endcapture

        echo hour | append: ':' | append: end_time_minute
    endcase
  endcapture

  assign starting_date = starting_date | default: 'now' | date: '%s'
  assign expiration_date = expiration_date | default: 'now' | date: '%s'
  assign hide_on_complete = true
  assign current_date = 'now' | date: '%s'
  assign time_difference = expiration_date | minus: current_date
-%}

{%- if current_date >= starting_date and current_date <= expiration_date -%}
  {%- assign is_visible = true -%}
{%- endif -%}

{%- unless use_timer -%}
  {%- assign is_visible = true -%}
{%- endunless -%}

{%- liquid
  assign animation_anchor = '#ProductsImage--' | append: section.id
  assign wrapper_width = section.settings.width
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- if is_visible -%}
  {%- capture style -%}
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  {%- endcapture -%}

  <section
    id="ProductsImage--{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-section-type="products-image"
    class="section-padding {{ color_scheme }}"
    style="{{ style }}"
  >
    {%- if section.blocks.size > 0 -%}
      <div class="brick__section{% if section.settings.reverse_blocks %} brick__section--reversed-mobile{% endif %} {{ wrapper_width }}">
        {%- liquid
          for block in section.blocks
            case block.type
              when 'products'
                render 'brick-products', block: block, animation_anchor: animation_anchor

              when 'image'
                render 'brick-image', block: block, animation_anchor: animation_anchor
            endcase
          endfor
        -%}
      </div>
    {%- else -%}
      {%- render 'no-blocks' -%}
    {%- endif -%}
  </section>
{%- endif -%}

